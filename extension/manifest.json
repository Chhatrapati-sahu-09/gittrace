{
  "manifest_version": 3,
  "name": "GitTrace",
  "version": "0.5.0",
  "description": "Analyzes GitHub repositories for AI-generated code, license risk, and security vulnerabilities.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": null,
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "GitTrace — AI Code Detector"
  },

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": ["storage", "tabs"],

  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "http://localhost:3001/*",
    "https://gittrace-api.onrender.com/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*", "src/*"],
      "matches": ["https://github.com/*"]
    }
  ]
}
