# Server
PORT=3001
NODE_ENV=development

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
# Scopes needed: public_repo
GITHUB_TOKEN=your_github_token_here

# GitTrace Shared Secret
GITTRACE_SECRET=dev-secret-day3

# Sapling AI Detection API
# Get free key from: https://sapling.ai/user/settings
AI_API_KEY=your_sapling_api_key_here
AI_API_URL=https://api.sapling.ai/api/v1/aidetect

# Demo mode - set true to skip real AI API calls
AI_DEMO_MODE=false